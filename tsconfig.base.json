{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@restaurant-platform/data-access-auth": [
        "libs/data-access/auth/src/index.ts"
      ],
      "@restaurant-platform/data-access-menu": [
        "libs/data-access/menu/src/index.ts"
      ],
      "@restaurant-platform/feature-auth": ["libs/feature-auth/src/index.ts"],
      "@restaurant-platform/feature-menu": ["libs/feature-menu/src/index.ts"],
      "@restaurant-platform/shared-types": ["libs/shared-types/src/index.ts"],
      "@restaurant-platform/state": ["libs/state/src/index.ts"],
      "@restaurant-platform/state-features": [
        "libs/state-features/src/index.ts"
      ],
      "@restaurant-platform/ui": ["libs/ui/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
